{
  "name": "image-converter-extension",
  "version": "1.0.0",
  "description": "An extension to convert images to different formats. Begone be the pain of downloading webp images!",
  "scripts": {
    "build": "webpack --config webpack.config.cjs",
    "watch": "webpack --config webpack.config.cjs --watch",
    "dev": "webpack --config webpack.config.cjs --mode development",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.{ts,css}\""
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.27",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^5.1.4"
  }
}
